# FlowCaptchaPT Configuration
FC_ADMIN_TOKEN=flowcaptcha-admin-2024
FC_MAX_CONCURRENT=3
FC_HEADLESS=true
FC_DEFAULT_COOLDOWN=10
FC_DEFAULT_COOLDOWN_FAIL=120
FC_DEFAULT_WAIT_DELAY=0
FC_HOST=0.0.0.0
FC_PORT=8000

# Profile Strategy: "single" | "rotation" | "ephemeral"
# - single: 1 Chrome profile (legacy behavior)
# - rotation: Round-robin across N profiles (anti-fingerprinting)
# - ephemeral: Fresh temp profile per request (zero tracking)
FC_PROFILE_STRATEGY=rotation
FC_ROTATION_PROFILE_COUNT=3

# Clear browsing data interval (minutes, 0 = disabled)
FC_CLEAR_DATA_INTERVAL=5

# Auto close tabs after token extraction (true/false, default false)
FC_AUTO_CLOSE_TABS=false
